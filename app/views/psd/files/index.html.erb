<div class="max-w-7xl mx-auto px-4 py-8">
  <!-- Header Section -->
  <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8 border-b border-slate-800 pb-6">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <span class="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-xs font-semibold tracking-wider uppercase text-slate-400">Biblioteca Ativa</span>
      </div>
      <h1 class="text-3xl font-extrabold tracking-tight text-white">Arquivos PSD</h1>
      <p class="text-sm text-slate-400 mt-1">Gerencie seus projetos, visualize contagem de camadas e faça download do fonte.</p>
    </div>

    <%= link_to new_psd_file_path, 
          class: "inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-500 shadow-md shadow-indigo-600/20 transition-all focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-slate-950", 
          aria_label: "Enviar novo arquivo PSD" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Enviar novo PSD
    <% end %>
  </header>

  <% if @psd_files.any? %>
    <!-- Gallery Grid -->
    <main class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <% @psd_files.each do |psd_file| %>
        <article class="group relative flex flex-col bg-slate-900/70 border border-slate-800 hover:border-slate-700/80 rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-slate-950/60">
          
          <!-- Image Container / Preview Box -->
          <div class="relative w-full h-48 bg-slate-950/80 border-b border-slate-800/80 flex items-center justify-center overflow-hidden">
            <% if psd_file.preview.attached? %>
              <%= image_tag psd_file.preview, 
                    alt: "Preview de #{psd_file.title}", 
                    class: "w-full h-full object-contain p-3 group-hover:scale-105 transition-transform duration-300" %>
            <% else %>
              <!-- Async Processing Placeholder -->
              <div class="flex flex-col items-center justify-center gap-2 text-slate-400 px-4 text-center" aria-live="polite">
                <svg class="w-6 h-6 animate-spin text-indigo-400" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="text-xs font-medium text-slate-400">Gerando preview...</span>
              </div>
            <% end %>

            <!-- Badge Type -->
            <span class="absolute top-3 right-3 px-2 py-0.5 rounded text-[10px] font-bold tracking-widest uppercase bg-slate-800/90 text-indigo-300 border border-slate-700/60 backdrop-blur-sm">
              PSD
            </span>
          </div>

          <!-- Card Details -->
          <div class="p-5 flex-1 flex flex-col justify-between">
            <div>
              <h2 class="text-base font-semibold text-white group-hover:text-indigo-300 transition-colors line-clamp-1" title="<%= psd_file.title %>">
                <%= psd_file.title %>
              </h2>

              <% if psd_file.try(:description).present? %>
                <p class="text-xs text-slate-400 mt-1 line-clamp-2"><%= psd_file.description %></p>
              <% end %>

              <!-- Metadata Section -->
              <div class="mt-4 pt-3 border-t border-slate-800/80 flex flex-wrap gap-2 text-xs">
                <% if psd_file.metadata.present? %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-slate-800/60 text-slate-300 border border-slate-700/50">
                    <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
                    </svg>
                    <%= psd_file.metadata["width"] %> × <%= psd_file.metadata["height"] %> px
                  </span>

                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-slate-800/60 text-slate-300 border border-slate-700/50">
                    <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                    </svg>
                    <%= psd_file.metadata["layer_count"] %> <%= "camada".pluralize(psd_file.metadata["layer_count"].to_i) %>
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-amber-500/10 text-amber-300 border border-amber-500/20 text-xs">
                    <svg class="w-3.5 h-3.5 animate-spin text-amber-400" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Processando metadados...
                  </span>
                <% end %>
              </div>
            </div>

            <!-- Download Action -->
            <% if psd_file.psd.attached? %>
              <div class="mt-4 pt-3 border-t border-slate-800/80">
                <%= link_to rails_blob_path(psd_file.psd, disposition: "attachment"), 
                      class: "w-full inline-flex items-center justify-center gap-2 px-3 py-2 rounded-xl text-xs font-semibold text-slate-200 hover:text-white bg-slate-800 hover:bg-slate-700/80 border border-slate-700/60 transition-all focus:outline-none focus:ring-2 focus:ring-indigo-500", 
                      aria_label: "Baixar arquivo #{psd_file.title}" do %>
                  <svg class="w-3.5 h-3.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                  </svg>
                  Baixar PSD
                <% end %>
              </div>
            <% end %>
          </div>
        </article>
      <% end %>
    </main>

  <% else %>
    <!-- Empty State -->
    <section class="flex flex-col items-center justify-center text-center py-16 px-4 bg-slate-900/40 border border-dashed border-slate-800 rounded-3xl">
      <div class="p-4 rounded-2xl bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 mb-4">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 002-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <h2 class="text-xl font-bold text-white mb-2">Nenhum PSD enviado ainda</h2>
      <p class="text-sm text-slate-400 max-w-sm mb-6">Sua galeria está vazia. Comece enviando seu primeiro projeto para visualizar as camadas e especificações técnicas.</p>
      
      <%= link_to new_psd_file_path, 
            class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-500 shadow-lg shadow-indigo-600/25 transition-all focus:outline-none focus:ring-2 focus:ring-indigo-500" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Enviar o primeiro PSD
      <% end %>
    </section>
  <% end %>
</div>